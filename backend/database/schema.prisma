// Prisma Schema — StellarTrustEscrow
//
// Run `npx prisma migrate dev` to create tables.
// Run `npx prisma generate` to regenerate the Prisma Client.
//
// TODO (contributor — medium, Issue #29):
// Review and finalize this schema. Consider:
// - Adding indexes for frequent query patterns (address lookups, status filters)
// - Adding created_at/updated_at to all tables (or using a Prisma plugin)
// - Whether dispute details need a separate table

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ── Escrows ───────────────────────────────────────────────────────────────────

model Escrow {
  /// On-chain escrow_id from the contract
  id                BigInt      @id
  clientAddress     String      @map("client_address")
  freelancerAddress String      @map("freelancer_address")
  arbiterAddress    String?     @map("arbiter_address")
  tokenAddress      String      @map("token_address")
  totalAmount       String      @map("total_amount")   // BigInt stored as string
  remainingBalance  String      @map("remaining_balance")
  status            EscrowStatus
  briefHash         String      @map("brief_hash")     // IPFS / content hash
  deadline          DateTime?
  createdAt         DateTime    @map("created_at")
  updatedAt         DateTime    @updatedAt @map("updated_at")
  /// Stellar ledger sequence when this escrow was created
  createdLedger     BigInt      @map("created_ledger")

  milestones        Milestone[]
  dispute           Dispute?

  @@index([clientAddress])
  @@index([freelancerAddress])
  @@index([status])
  // Composite index for filtered + sorted list queries
  @@index([status, createdAt(sort: Desc)])
  @@map("escrows")
}

// ── Milestones ────────────────────────────────────────────────────────────────

model Milestone {
  id              Int             @id @default(autoincrement())
  /// on-chain milestone index within the escrow
  milestoneIndex  Int             @map("milestone_index")
  escrowId        BigInt          @map("escrow_id")
  title           String
  descriptionHash String          @map("description_hash")
  amount          String          // BigInt as string
  status          MilestoneStatus
  submittedAt     DateTime?       @map("submitted_at")
  resolvedAt      DateTime?       @map("resolved_at")

  escrow          Escrow          @relation(fields: [escrowId], references: [id])

  @@unique([escrowId, milestoneIndex])
  @@index([escrowId])
  @@map("milestones")
}

// ── Reputation ────────────────────────────────────────────────────────────────

model ReputationRecord {
  address           String   @id
  totalScore        BigInt   @default(0) @map("total_score")
  completedEscrows  Int      @default(0) @map("completed_escrows")
  disputedEscrows   Int      @default(0) @map("disputed_escrows")
  disputesWon       Int      @default(0) @map("disputes_won")
  totalVolume       String   @default("0") @map("total_volume") // BigInt as string
  lastUpdated       DateTime @map("last_updated")
  updatedAt         DateTime @updatedAt @map("updated_at")

  @@index([totalScore(sort: Desc)])
  @@map("reputation_records")
}

// ── Disputes ─────────────────────────────────────────────────────────────────

model Dispute {
  id              Int       @id @default(autoincrement())
  escrowId        BigInt    @unique @map("escrow_id")
  raisedByAddress String    @map("raised_by_address")
  raisedAt        DateTime  @map("raised_at")
  resolvedAt      DateTime? @map("resolved_at")
  /// Amount returned to client on resolution
  clientAmount    String?   @map("client_amount")
  /// Amount sent to freelancer on resolution
  freelancerAmount String?  @map("freelancer_amount")
  /// Address that resolved the dispute (arbiter or admin)
  resolvedBy      String?   @map("resolved_by")
  /// Outcome description
  resolution      String?

  escrow          Escrow    @relation(fields: [escrowId], references: [id])

  @@index([raisedByAddress])
  @@map("disputes")
}

// ── Contract Events ───────────────────────────────────────────────────────────

/// Indexed record of every Soroban contract event emitted by the escrow contract.
/// Enables historical queries and real-time subscriptions without hitting the chain.
model ContractEvent {
  id            Int      @id @default(autoincrement())
  /// Stellar ledger sequence this event was emitted in
  ledger        BigInt
  /// Ledger close timestamp
  ledgerAt      DateTime @map("ledger_at")
  /// Contract address that emitted the event
  contractId    String   @map("contract_id")
  /// Short event name derived from topic[0] (e.g. "esc_crt", "mil_apr")
  eventType     String   @map("event_type")
  /// Escrow ID extracted from topic[1] (null for contract-wide events)
  escrowId      BigInt?  @map("escrow_id")
  /// Full JSON-serialised topic array
  topics        Json
  /// Full JSON-serialised data payload
  data          Json
  /// Unique transaction hash + event index to prevent duplicate inserts
  txHash        String   @map("tx_hash")
  eventIndex    Int      @map("event_index")

  @@unique([txHash, eventIndex])
  @@index([eventType])
  @@index([escrowId])
  @@index([ledger])
  @@index([ledgerAt(sort: Desc)])
  @@map("contract_events")
}

// ── Indexer State ─────────────────────────────────────────────────────────────

/// Tracks the last ledger processed so the indexer can resume after restart.
model IndexerState {
  id                  Int    @id @default(1)
  lastProcessedLedger BigInt @default(0) @map("last_processed_ledger")

  @@map("indexer_state")
}

// ── Payments ─────────────────────────────────────────────────────────────────

model Payment {
  id                String        @id @default(cuid())
  address           String                              // Stellar address of payer
  escrowId          BigInt?       @map("escrow_id")     // linked escrow (nullable until funded)
  stripeSessionId   String?       @unique @map("stripe_session_id")
  stripePaymentIntent String?     @unique @map("stripe_payment_intent")
  amountFiat        Int           @map("amount_fiat")   // in cents (USD)
  amountCrypto      String?       @map("amount_crypto") // XLM/USDC amount after conversion
  currency          String        @default("usd")
  status            PaymentStatus @default(Pending)
  refundId          String?       @map("refund_id")     // Stripe refund ID
  createdAt         DateTime      @default(now()) @map("created_at")
  updatedAt         DateTime      @updatedAt @map("updated_at")

  @@index([address])
  @@index([status])
  @@map("payments")
}

// ── KYC ──────────────────────────────────────────────────────────────────────

model KycVerification {
  id              Int       @id @default(autoincrement())
  address         String    @unique
  applicantId     String?   @unique @map("applicant_id")  // Sumsub applicant ID
  status          KycStatus @default(Pending)
  reviewResult    String?   @map("review_result")         // approved | declined
  rejectLabels    String[]  @map("reject_labels")         // Sumsub rejection reasons
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  @@index([status])
  @@map("kyc_verifications")
