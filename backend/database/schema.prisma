// ── Enums ─────────────────────────────────────────────────────────────────────

enum EscrowStatus {
  Active
  Completed
  Disputed
  Cancelled
}

enum MilestoneStatus {
  Pending
  Submitted
  Approved
  Rejected
}

enum KycStatus {
  Pending
  Init
  Processing
  Approved
  Declined
}

enum PaymentStatus {
  Pending
  Processing
  Completed
  Failed
  Refunded
}
